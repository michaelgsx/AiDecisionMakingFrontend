# 你的 API 根地址，不要末尾斜杠。
# 本地写入 DynamoDB：先 `cd server && npm install && cp .env.example .env` 填表名后 `npm start`，
# 此处填 http://localhost:8787
# 云上：SAM 部署完成后把 Outputs.ApiUrl 贴到这里
VITE_API_BASE_URL=http://localhost:8787

# Ops 权限：会以 Authorization: Bearer <token> 发送（需与 server 环境变量 OPS_TOKEN 一致）
VITE_OPS_TOKEN=

# 本地无后端时设为 true，使用内置 Mock 看 UI
VITE_USE_MOCK=false
