# API base URL (no trailing slash).
# Point to the Java backend in AiDecisionMakingBackend:
#   cd ../AiDecisionMakingBackend/backend && ./mvnw spring-boot:run
# Then use http://localhost:8787
# Production: your hosted API URL (e.g. Azure App Service) — no trailing slash.
VITE_API_BASE_URL=http://localhost:8787

# Ops auth: Authorization: Bearer <token>; must match backend OPS_TOKEN when set.
VITE_OPS_TOKEN=

# true = use built-in mock UI without calling the API.
VITE_USE_MOCK=false
