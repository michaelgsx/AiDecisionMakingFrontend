# Azure SQL Database (logical server host ends with .database.windows.net).
# If you use Azure Database for MySQL instead, you need a different driver (e.g. mysql2); this app targets Azure SQL.
# Example logical server (West US 2): ai-rag-sql-server.database.windows.net
AZURE_SQL_SERVER=ai-rag-sql-server.database.windows.net
AZURE_SQL_PORT=1433
# Logical database name (create in Azure Portal under the server)
AZURE_SQL_DATABASE=your_database_name
AZURE_SQL_USER=your_sql_login
AZURE_SQL_PASSWORD=your_password

# TLS: keep encrypt on for Azure (default). For some dev tunnels set TRUST to true.
AZURE_SQL_ENCRYPT=true
AZURE_SQL_TRUST_CERTIFICATE=false

# Optional: override fully-qualified table (default dbo.risk_ingest_records)
# AZURE_SQL_TABLE=dbo.risk_ingest_records

# Must match frontend VITE_OPS_TOKEN when set; omit to skip auth (local dev only).
OPS_TOKEN=

# Optional: allowed browser origins, comma-separated; omit to allow any origin.
# CORS_ORIGIN=http://localhost:5173

# Local API listen port.
PORT=8787
